# JWT
JWT_SECRET=your-jwt-secret-here

# MySQL / RDS
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASS=your-db-password
DB_NAME=whatpl

# AWS S3 (s3.js에서 S3_BUCKET_NAME 사용)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name

# CloudFront (선택 — 설정 시 S3 URL 대신 CloudFront URL 사용)
CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net

# CORS — 프론트엔드 주소 (S3 정적 사이트 또는 CloudFront 도메인)
FRONTEND_URL=https://your-frontend-domain.com

# 서버 포트
PORT=4000

# Initial admin seed passwords
# Option A: set one temporary password for all 4 admins, run npm run seed:admins, then change passwords immediately.
ADMIN_INITIAL_PASSWORD=change-this-temporary-password
# Option B: set separate passwords instead of ADMIN_INITIAL_PASSWORD.
# ADMIN_HYUNSU_PASSWORD=
# ADMIN_JUYEON_PASSWORD=
# ADMIN_INHO_PASSWORD=
# ADMIN_WONJUN_PASSWORD=
